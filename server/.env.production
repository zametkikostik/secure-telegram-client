# ===========================================
# PRODUCTION CONFIGURATION
# ===========================================
# Используйте эти переменные окружения в production
# НЕ храните этот файл в git!
# ===========================================

# SERVER
SERVER_ADDR=0.0.0.0:8008
DATABASE_URL=postgresql://user:password@localhost:5432/liberty_reach
# Или для SQLite (не рекомендуется для production)
# DATABASE_URL=sqlite:/app/data/liberty_reach.db

# JWT Secret (ОБЯЗАТЕЛЬНО измените!)
# Сгенерируйте: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_RANDOM_STRING

# Uploads
UPLOADS_DIR=/app/uploads

# Logging
RUST_LOG=info,tower_http=debug,axum::rejection=trace

# ===========================================
# SECURITY
# ===========================================

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS (укажите ваши домены)
ALLOWED_ORIGINS=https://libertyreach.io,https://app.libertyreach.io

# Session timeout (30 дней)
SESSION_TIMEOUT_DAYS=30

# ===========================================
# DATABASE (PostgreSQL recommended)
# ===========================================

# PostgreSQL connection pool
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_CONNECT_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600

# ===========================================
# WEB3
# ===========================================

# Admin wallet for fees
ADMIN_WALLET=0xYourAdminWalletAddressHere

# 0x Protocol
ZERO_EX_API_KEY=your-0x-api-key

# ABCEX
ABCEX_API_KEY=your-abcex-api-key

# Bitget
BITGET_API_KEY=your-bitget-api-key
BITGET_SECRET_KEY=your-bitget-secret-key
BITGET_PASSPHRASE=your-bitget-passphrase

# ===========================================
# AI SERVICES
# ===========================================

# Qwen API (Alibaba Cloud)
QWEN_API_KEY=sk-your-qwen-api-key

# ===========================================
# PUSH NOTIFICATIONS
# ===========================================

# Firebase Cloud Messaging
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ===========================================
# MONITORING
# ===========================================

# Sentry (errors tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/1234567

# Prometheus metrics endpoint
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================
# PERFORMANCE
# ===========================================

# Worker threads (0 = auto)
TOKIO_WORKER_THREADS=0

# Max upload size (in bytes, default 50MB)
MAX_UPLOAD_SIZE=52428800

# Connection keep-alive timeout
KEEP_ALIVE_TIMEOUT=60
