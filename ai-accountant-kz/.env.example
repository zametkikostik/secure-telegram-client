# AI-Бухгалтер для ИП - Конфигурация

# ===== Приложение =====
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your-super-secret-key-min-32-chars

# ===== База данных =====
DATABASE_URL=postgresql://accountant:changeme123@db:5432/accountant
DATABASE_URL_SQLITE=sqlite:///./data/accountant.db

# ===== Redis (Celery) =====
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== AI (DashScope/Qwen) =====
OPENAI_API_KEY=your_dashscope_api_key
OPENAI_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_CONFIDENCE_THRESHOLD=0.95

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ENABLED=false

# ===== Банки =====
KASPI_API_KEY=your_kaspi_api_key
KASPI_MERCHANT_ID=your_merchant_id
HALYK_API_KEY=your_halyk_api_key
HALYK_CLIENT_ID=your_client_id

# ===== OCR (распознавание чеков) =====
TESSERACT_CMD=tesseract

# ===== Логирование =====
LOG_LEVEL=INFO
LOG_FILE=logs/accountant.log

# ===== CORS =====
CORS_ORIGINS=["*"]

# ===== Rate Limiting =====
RATE_LIMIT_PER_MINUTE=60

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@ai-accountant.kz

# ===== SMS (Казахстан) =====
SMS_PROVIDER=sms_kz  # sms_kz, oxygencity, twilio
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=AI-Buhgalter
