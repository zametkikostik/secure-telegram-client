# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_accountant_kz
# Kaspi Pay API
KASPI_API_KEY=your_kaspi_api_key
KASPI_API_URL=https://aipay.kz/api
# Halyk Open Banking
HALYK_CLIENT_ID=your_client_id
HALYK_CLIENT_SECRET=your_client_secret
HALYK_API_URL=https://api.halykbank.kz
# AI (OpenClaw / Qwen)
OPENCLAW_API_KEY=your_openclaw_key
QWEN_API_KEY=your_qwen_key
QWEN_MODEL=qwen-2.5-plus
# Security
SECRET_KEY=your_secret_key_for_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# App
APP_ENV=development
DEBUG=True
LOG_LEVEL=DEBUG
DATA_REGION=kz
