# AI Accountant KZ Tax API - Environment Variables
# Скопируйте в .env и заполните значениями

# ===== Приложение =====
APP_NAME=AI Accountant KZ Tax API
ENVIRONMENT=production
DEBUG=false
API_VERSION=v1

# ===== Безопасность =====
# SECRET_KEY должен быть минимум 32 символа
SECRET_KEY=your-super-secret-key-min-32-chars-change-this

# API Key для аутентификации запросов (обязательно измените!)
API_KEY=your-api-key-change-this-in-production

# ===== AI (OpenRouter/DashScope) =====
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=your_dashscope_api_key
OPENAI_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Логирование =====
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_FILE=logs/accountant.log

# ===== CORS =====
# Укажите только доверенные домены
CORS_ORIGINS=["https://ai-accountant.kz", "https://www.ai-accountant.kz"]

# ===== Rate Limiting =====
RATE_LIMIT_PER_MINUTE=60

# ===== Telegram (опционально) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ===== Банки (опционально) =====
KASPI_API_KEY=
KASPI_MERCHANT_ID=
HALYK_API_KEY=
HALYK_CLIENT_ID=
