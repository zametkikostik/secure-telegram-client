# ============================================================================
# Secure Messenger Smart Contracts - Environment Variables
# ============================================================================

# Private key of deployer wallet (DO NOT commit this!)
PRIVATE_KEY=0x...

# RPC URLs
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://eth.llamarpc.com

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your-api-key-here

# Gas Reporter (optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your-api-key-here

# ============================================================================
# Deployment Configuration
# ============================================================================

# Platform wallets (replace with actual addresses)
PLATFORM_TREASURY=0x...
TEAM_WALLET=0x...
TREASURY_WALLET=0x...
MARKETING_WALLET=0x...
RESERVE_WALLET=0x...

# Initial arbiters (at least 2 recommended)
ARBITER_1=0x...
ARBITER_2=0x...
