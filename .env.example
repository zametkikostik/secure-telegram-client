# Liberty Reach Messenger v2.0
# Environment Variables Template
# Скопируйте этот файл в .env.local и заполните своими значениями

# =============================================================================
# DATABASE
# =============================================================================
# Сгенерируйте ключ: cargo run --bin generate_key
DB_ENCRYPTION_KEY=

# =============================================================================
# BITGET API (Cryptocurrency Exchange)
# Получить: https://www.bitget.com → Profile → API Management
# =============================================================================
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
BITGET_TESTNET=true

# =============================================================================
# 0x PROTOCOL (DEX)
# Получить: https://0x.org → Dashboard
# =============================================================================
ZEROEX_API_KEY=
ZEROEX_CHAIN_ID=1

# =============================================================================
# ABCEX (Payment Gateway)
# Получить: https://abcex.com/merchant
# =============================================================================
ABCEX_API_KEY=
ABCEX_MERCHANT_ID=
ABCEX_TESTNET=true

# =============================================================================
# QWEN API (AI Translation)
# Получить: https://dashscope.console.aliyun.com/
# =============================================================================
QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=2000

# =============================================================================
# INFURA (Web3 Infrastructure)
# Получить: https://infura.io → Create Project
# =============================================================================
INFURA_PROJECT_ID=
INFURA_PROJECT_SECRET=

# =============================================================================
# FIREBASE (Push Notifications)
# Получить: https://console.firebase.google.com/
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# =============================================================================
# SIP (VoIP)
# =============================================================================
SIP_SERVER=
SIP_USERNAME=
SIP_PASSWORD=
SIP_DOMAIN=

# =============================================================================
# APPLICATION
# =============================================================================
APP_DEBUG=true
APP_LOG_LEVEL=info
APP_CONFIG_PATH=config.toml
