# Liberty Reach Messenger v2.0
# Environment Variables (CRITICAL - DO NOT COMMIT!)
# Этот файл содержит секретные ключи - НИКОГДА не коммитьте в git!

# =============================================================================
# DATABASE
# =============================================================================
DB_ENCRYPTION_KEY=GENERATE_WITH_cargo_run_--bin_generate_key

# =============================================================================
# BITGET API (Cryptocurrency Exchange)
# =============================================================================
BITGET_API_KEY=YOUR_BITGET_API_KEY
BITGET_SECRET_KEY=YOUR_BITGET_SECRET_KEY
BITGET_PASSPHRASE=YOUR_BITGET_PASSPHRASE
BITGET_TESTNET=true

# =============================================================================
# 0x PROTOCOL (DEX)
# =============================================================================
ZEROEX_API_KEY=YOUR_0X_API_KEY
ZEROEX_CHAIN_ID=1

# =============================================================================
# ABCEX (Payment Gateway)
# =============================================================================
ABCEX_API_KEY=YOUR_ABCEX_API_KEY
ABCEX_MERCHANT_ID=YOUR_MERCHANT_ID
ABCEX_TESTNET=true

# =============================================================================
# QWEN API (AI Translation)
# =============================================================================
QWEN_API_KEY=YOUR_QWEN_DASHSCOPE_API_KEY
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=2000

# =============================================================================
# INFURA (Web3 Infrastructure)
# =============================================================================
INFURA_PROJECT_ID=YOUR_INFURA_PROJECT_ID
INFURA_PROJECT_SECRET=YOUR_INFURA_PROJECT_SECRET

# =============================================================================
# FIREBASE (Push Notifications)
# =============================================================================
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CREDENTIALS_PATH=path/to/firebase_credentials.json

# =============================================================================
# SIP (VoIP)
# =============================================================================
SIP_SERVER=sip.example.com:5060
SIP_USERNAME=YOUR_SIP_USERNAME
SIP_PASSWORD=YOUR_SIP_PASSWORD
SIP_DOMAIN=example.com

# =============================================================================
# APPLICATION
# =============================================================================
APP_DEBUG=true
APP_LOG_LEVEL=info
APP_CONFIG_PATH=config.toml
