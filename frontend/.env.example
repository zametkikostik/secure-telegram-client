# API URL основного сервера (Axum backend)
VITE_API_URL=http://localhost:3000

# Cloudflare Worker URL для fallback и offline уведомлений
# Production URL после деплоя 7 апреля 2026
VITE_CLOUDFLARE_WORKER_URL=https://secure-messenger-push.zametkikostik.workers.dev

# ============================================================================
# AI Integration (Multi-Provider Support)
# ============================================================================
# Get API keys:
#   OpenRouter:  https://openrouter.ai/keys (free tier available)
#   Anthropic:   https://console.anthropic.com
#   OpenAI:      https://platform.openai.com/api-keys

# OpenRouter — основной AI провайдер (агрегирует 200+ моделей)
VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Local Ollama URL (для локальных моделей без API ключа)
VITE_OLLAMA_URL=http://localhost:11434

# Предпочитать локальные модели вместо облачных (true/false)
VITE_AI_PREFER_LOCAL=false

# AI провайдер по умолчанию: openrouter, ollama, anthropic, openai
VITE_AI_DEFAULT_PROVIDER=openrouter

# ============================================================================
# Web3 / Blockchain Integration
# ============================================================================
# Smart contract addresses (update after deployment)

# P2P Escrow contract address
VITE_P2P_ESCROW_ADDRESS=0x...

# Fee Splitter contract address
VITE_FEE_SPLITTER_ADDRESS=0x...

# Network ID (1 = Mainnet, 11155111 = Sepolia, 31337 = Local)
VITE_CHAIN_ID=11155111

# RPC URL for Web3 provider
VITE_RPC_URL=https://rpc.sepolia.org

# Block explorer URL
VITE_EXPLORER_URL=https://sepolia.etherscan.io

# Enable Web3 features (true/false)
VITE_WEB3_ENABLED=true

# ============================================================================
# WebRTC Voice/Video Calls
# ============================================================================
# STUN servers for NAT traversal
VITE_WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server (optional, for symmetric NAT)
# Get free TURN: https://www.metered.ca/tools/openrelay/
VITE_WEBRTC_TURN_SERVER=turn:openrelay.metered.ca:443
VITE_WEBRTC_TURN_USERNAME=
VITE_WEBRTC_TURN_CREDENTIAL=

# Enable video calls (true/false)
VITE_WEBRTC_VIDEO_ENABLED=true

# Max call bitrate (bps) — 0 = auto
VITE_WEBRTC_MAX_BITRATE=0

# ============================================================================
# Stickers & Reactions
# ============================================================================
# Sticker Pack CDN URL (base URL for sticker images)
VITE_STICKER_CDN_URL=https://stickers.secure-messenger.local

# Default emoji reactions (comma-separated)
VITE_REACTION_EMOJIS=👍,👎,❤️,🔥,😂,😮,😢,🎉

# Enable custom reactions (true/false)
VITE_CUSTOM_REACTIONS_ENABLED=true

# Max reactions per message
VITE_MAX_REACTIONS_PER_MESSAGE=11

# ============================================================================
# Stories
# ============================================================================
# Enable stories feature (true/false)
VITE_STORIES_ENABLED=true

# Story duration (hours) — default 24h like Telegram
VITE_STORY_DURATION_HOURS=24

# Max stories per user (24h window)
VITE_MAX_STORIES_PER_DAY=5

# Story viewer count (true/false)
VITE_STORY_VIEWER_COUNT_ENABLED=true

# ============================================================================
# Bot Platform
# ============================================================================
# Bot API base URL (for external bot developers)
VITE_BOT_API_URL=/api/v1/bots

# Enable bot marketplace (true/false)
VITE_BOT_STORE_ENABLED=true

# Max bots per user
VITE_MAX_BOTS_PER_USER=10

# Bot webhook timeout (ms)
VITE_BOT_WEBHOOK_TIMEOUT=5000

# Enable AI bot (OpenRouter integration)
VITE_BOT_AI_ENABLED=true

# ============================================================================
# Payments & Monetization (Stripe + Crypto)
# ============================================================================
# Stripe Publishable Key
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe API URL (for server-side)
VITE_STRIPE_API_URL=https://api.stripe.com/v1

# Enable Stripe checkout (true/false)
VITE_STRIPE_ENABLED=true

# Crypto payment settings
VITE_CRYPTO_ENABLED=true

# Supported crypto tokens for payments
VITE_CRYPTO_TOKENS=ETH,USDC,USDT

# Default network for crypto payments (1 = Mainnet, 11155111 = Sepolia)
VITE_CRYPTO_NETWORK=11155111

# Premium subscription prices
VITE_PRICE_PREMIUM_MONTHLY=500
VITE_PRICE_PRO_MONTHLY=1500

# Tipping settings
VITE_TIP_ENABLED=true
VITE_MIN_TIP_AMOUNT=1
VITE_MAX_TIP_AMOUNT=1000

# Credit system
VITE_CREDIT_TO_USD_RATE=0.01
VITE_MIN_CREDIT_PURCHASE=100
VITE_MAX_CREDIT_PURCHASE=10000
