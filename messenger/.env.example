# AI Module Configuration — Multi-Provider Support (PHASE 4.5)
#
# Get API keys:
#   OpenRouter:  https://openrouter.ai/keys (free tier available)
#   Anthropic:   https://console.anthropic.com
#   OpenAI:      https://platform.openai.com/api-keys
#   Groq:        https://console.groq.com/keys
#   Mistral:     https://console.mistral.ai/api-keys
#
# Local models (Ollama):
#   ollama pull qwen2.5:14b          (translation, summary)
#   ollama pull qwen2.5-coder:14b    (code generation)
#   ollama pull qwen2.5:7b           (general chat, lighter)

# ---------------------------------------------------------------------------
# OpenRouter — aggregates 200+ models, free tier available
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------------------
# Local Ollama URL — no API key needed, just running Ollama
# ---------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Anthropic — direct Claude API (optional)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------------------------------------------------------------------------
# OpenAI — direct GPT API (optional)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Groq — fast inference (optional)
# ---------------------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# ---------------------------------------------------------------------------
# Mistral AI (optional)
# ---------------------------------------------------------------------------
# MISTRAL_API_KEY=...

# ---------------------------------------------------------------------------
# Behavior
# ---------------------------------------------------------------------------

# Prefer local Ollama over cloud providers
# Set to "true" or "1" to try local first
AI_PREFER_LOCAL=false

# Default provider when multiple are configured
# Options: openrouter, ollama, anthropic, openai, groq, mistral
AI_DEFAULT_PROVIDER=openrouter
