# ============================================================================
# Secure Messenger — Self-Hosted Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
#           Use strong passwords in production!
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Backend port (internal)
BACKEND_PORT=3000

# ============================================================================
# PostgreSQL Database
# ============================================================================

# Database credentials — CHANGE THESE IN PRODUCTION!
POSTGRES_USER=messenger
POSTGRES_PASSWORD=changeme-use-openssl-rand-base64-32
POSTGRES_DB=messenger

# External port (bind to 127.0.0.1 for security)
POSTGRES_EXTERNAL_PORT=127.0.0.1:5432

# ============================================================================
# Redis Cache
# ============================================================================

# Redis password — CHANGE THIS!
REDIS_PASSWORD=changeme-use-openssl-rand-base64-32

# Max memory for Redis (cache eviction policy: allkeys-lru)
REDIS_MAX_MEMORY=256mb

# External port (bind to 127.0.0.1)
REDIS_EXTERNAL_PORT=127.0.0.1:6379

# ============================================================================
# MinIO — S3-Compatible Object Storage
# ============================================================================

# MinIO credentials — CHANGE THESE!
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-use-openssl-rand-base64-32-at-least-32-chars

# Bucket name for file storage
MINIO_BUCKET=messenger-files

# MinIO ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=127.0.0.1:9001

# ============================================================================
# JWT Authentication
# ============================================================================

# JWT secret — MUST be a random 256-bit (64 hex chars) string!
# Generate with: openssl rand -base64 64 | tr -d '/+=' | head -c 64
JWT_SECRET=change-this-to-random-256-bit-secret-minimum-64-characters-long

# Token expiry in seconds (default: 24 hours)
JWT_EXPIRY=86400

# ============================================================================
# Security Settings
# ============================================================================

# Rate limit: max requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Max upload file size in MB
MAX_UPLOAD_SIZE_MB=50

# ============================================================================
# Cloudflare Worker (Optional — for push notifications)
# ============================================================================

# Cloudflare Worker URL for offline message delivery
# Example: https://secure-messenger-push.your-domain.workers.dev
CLOUDFLARE_WORKER_URL=

# ============================================================================
# Nginx Reverse Proxy
# ============================================================================

# HTTP port (public)
NGINX_HTTP_PORT=80

# HTTPS port (public) — configure TLS in nginx/conf.d/
NGINX_HTTPS_PORT=443

# ============================================================================
# Optional: Email (for notifications, account recovery)
# ============================================================================

# SMTP server configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com

# ============================================================================
# Optional: TLS/SSL (Let's Encrypt)
# ============================================================================

# Domain name for TLS certificate
DOMAIN_NAME=

# Email for Let's Encrypt notifications
TLS_EMAIL=
